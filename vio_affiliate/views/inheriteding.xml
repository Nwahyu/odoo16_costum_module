    <!-- extend form partner -->
    <record id="view_partner_form_inherit_affiliate" model="ir.ui.view">
        <field name="name">res.partner.view.form.inheri.affiliate</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="base.view_partner_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='vat']" position="after">
                <field name="nik"/>
                <field name="pekerjaan" />
                <field name="medsos_ig" />
                <field name="medsos_tiktok" />
                <field name="nama_bank" />
                <field name="no_rek" />
                <field name="nama_rek" />
                <field name="cabang_bank"/>
                <field name="pw"/>
            </xpath>
        </field>
    </record>


