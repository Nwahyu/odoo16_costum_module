<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data>
        <!-- List View -->
        <record model="ir.ui.view" id="cabang_cabang_tree">
            <field name="name">cabang.cabang.tree</field>
            <field name="model">cabang.cabang</field>
            <field name="arch" type="xml">
                <tree>
                    <field name="name"/>
                    <field name="address"/>
                    <field name="phone"/>
                    <field name="map_link"/>
                    <field name="active"/>
                </tree>
            </field>
        </record>

        <!-- Form View -->
        <record model="ir.ui.view" id="cabang_cabang_form">
            <field name="name">cabang.cabang.form</field>
            <field name="model">cabang.cabang</field>
            <field name="arch" type="xml">
                <form>
                    <header>
                        <button name="action_toggle_active" string="Toggle Active" type="object" class="btn-primary"/>
                    </header>
                    <sheet>
                        <group>
                            <group>
                                <field name="name"/>
                                <field name="address"/>
                                <field name="phone"/>
                                <field name="map_link"/>
                                <field name="active"/>
                            </group>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

        <!-- Action -->
        <record model="ir.actions.act_window" id="cabang_cabang_action">
            <field name="name">VIO Clinic Branches</field>
            <field name="res_model">cabang.cabang</field>
            <field name="view_mode">tree,form</field>
        </record>

        <!-- Menu Item -->
        <menuitem
            id="cabang_cabang_menu"
            name="Cabang"
            action="cabang_cabang_action"
            parent="aff_vio_root"
            sequence="10"/>

    </data>
</odoo>
