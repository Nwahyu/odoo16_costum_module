<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data>
        <!-- List View -->
        <record model="ir.ui.view" id="aff_trx_tree">
            <field name="name">aff_trx.tree</field>
            <field name="model">aff.trx</field>
            <field name="arch" type="xml">
                <tree>
                    <field name="nama"/>
                    <field name="total_trx" />
                    <field name="token_affiliator" />
                    <field name="user_id" />
                    <field name="komisi" />
                    <field name="persen_komisi"/>
                    <field name="tipe_komisi" />
                    <field name="kategori_trx"/>
                    <field name="status"/>
                    <field name="trx_date"/>
                </tree>
            </field>
        </record>
        
        <!-- Form View -->
        <record model="ir.ui.view" id="aff_trx_form">
            <field name="name">aff_trx.form</field>
            <field name="model">aff.trx</field>
            <field name="arch" type="xml">
                <form>
                    <header>
                        <button name="approve" string="Approve" type="object" state="waiting"/>
                        <button name="reject" string="Reject" type="object" state="waiting"/>
                    </header>
                    <sheet>
                        <group>
                            <group>
                                <field name="nama"/>
                                <field name="total_trx" />
                                <field name="token_affiliator" />
                                <field name="user_id" />
                                <field name="komisi" />
                                <field name="persen_komisi"/>
                                <field name="tipe_komisi" />
                                <field name="kategori_trx"/>
                                <field name="status"/>
                                <field name="trx_date"/>
                            </group>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

        <record model="ir.actions.act_window" id="aff_trx_action">
            <field name="name">Aff Trx</field>
            <field name="res_model">aff.trx</field>
            <field name="view_mode">tree,form</field>
        </record>


        <!-- =============================================================== -->

        <record id="payout_trx_view_tree" model="ir.ui.view">
            <field name="name">payout.trx.view.tree</field>
            <field name="model">payout.trx</field>
            <field name="arch" type="xml">
                <tree string="">
                    <field name="nama"/>
                    <field name="user_id"/>
                    <field name="token_affiliator"/>
                    <field name="jumlah_payout"/>
                    <field name="trx_date"/>
                </tree>
            </field>
        </record>

        <record id="payout_trx_view_form" model="ir.ui.view">
            <field name="name">payout_trx.view.form</field>
            <field name="model">payout.trx</field>
            <field name="arch" type="xml">
                <form string="">
                    <sheet>
                        <group>
                            <field name="nama"/>
                            <field name="user_id"/>
                            <field name="token_affiliator"/>
                            <field name="jumlah_payout"/>
                            <field name="trx_date"/>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

        <record id="payout_trx_action" model="ir.actions.act_window">
            <field name="name">Payout Trx</field>
            <field name="res_model">payout.trx</field>
            <field name="view_mode">tree,form</field>
        </record>
