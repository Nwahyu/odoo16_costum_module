<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="res_config_settings_view_form_vio_db_block" model="ir.ui.view">
        <field name="name">res.config.settings.view.form.inherit.vio.db.block</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="base.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//div[hasclass('settings')]" position="inside">
                <div class="app_settings_block" data-string="Vio DB Block" string="Vio DB Block" data-key="vio_disable_web_database">
                    <h2>Database Access Blocking</h2>
                    <div class="row mt16 o_settings_container">
                        <div class="col-12 col-lg-6 o_setting_box">
                            <div class="o_setting_left_pane">
                                <field name="enable_db_block"/>
                            </div>
                            <div class="o_setting_right_pane">
                                <label for="enable_db_block"/>
                                <div class="text-muted">
                                    When enabled, /web/database endpoints are blocked and redirected to /web/login.
                                </div>
                            </div>
                        </div>
                        <div class="col-12 col-lg-6 o_setting_box">
                            <div class="o_setting_left_pane"/>
                            <div class="o_setting_right_pane">
                                <label for="backup_header_value"/>
                                <div class="text-muted">
                                    Value that the X-name-header must match to allow backup access when blocking is enabled.
                                </div>
                                <field name="backup_header_value"/>
                            </div>
                        </div>
                    </div>
                </div>
            </xpath>
        </field>
    </record>
</odoo>
