<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="tag_kriteria_view_tree" model="ir.ui.view">
        <field name="name">tag.kriteria.view.tree</field>
        <field name="model">tag.kriteria</field>
        <field name="arch" type="xml">
            <tree string="">
                <field name="nama" />
                <field name="stage_id"/>
            </tree>
        </field>
    </record>

    <record id="tag_kriteria_view_form" model="ir.ui.view">
        <field name="name">tag.kriteria.view.form</field>
        <field name="model">tag.kriteria</field>
        <field name="arch" type="xml">
            <form string="">
                <sheet>
                    <group>
                        <field name="nama" />
                        <field name="stage_id"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="tag_kriteria_action" model="ir.actions.act_window">
        <field name="name">tag kriteria</field>
        <field name="res_model">tag.kriteria</field>
        <field name="view_mode">tree,form</field>
        <field name="domain">[]</field>
        <field name="context">{}</field>
        <field name="help" type="html">
            <p>ini kriteria</p>
        </field>
    </record>

