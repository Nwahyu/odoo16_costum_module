<odoo>
	<data>
		<record model="ir.ui.view" id="view_assistant_doctor_details">
			<field name="name">assistant_doctor_details</field>
			<field name="model">assistant.doctor.details</field>
			<field name="type">form</field>
			<field name="arch" type="xml">
				<form string='Assistant Doctor Details'>
					<sheet>
						<group colspan="4" col="4" string="Left Eye">
							<field name="left_distance_id"/>
							<field name="left_near_id"/>
							<field name="left_with_glasses_id"/>
							<field name="left_without_glasses_id"/>
							<field name="left_pin_id"/>
							<field name="left_iop_id"/>
						</group>
						<group colspan="4" col="4" string="Right Eye">
							<field name="right_distance_id"/>
							<field name="right_near_id"/>
							<field name="right_with_glasses_id"/>
							<field name="right_without_glasses_id"/>
							<field name="right_pin_id"/>
							<field name="right_iop_id"/>
						</group>
							<field name="glass_prescription_line_ids"/>
					</sheet>
				</form>
			</field>
		</record>
		<record model="ir.ui.view" id="assistant_doctor_details_tree">
			<field name="name">assistant_doctor_details</field>
			<field name="model">assistant.doctor.details</field>
			<field name="type">tree</field>
			<field name="arch" type="xml">
				<tree>
					<field name="left_distance_id" string="L.Dist"/>
					<field name="left_near_id" string="L.Near"/>
					<field name="left_with_glasses_id" string="L.With Glasses"/>
					<field name="left_without_glasses_id" string="L.W/O Glasses"/>
					<field name="left_pin_id" string="L.PIN"/>
					<field name="left_iop_id" string="L.IOP"/>
					
					<field name="right_distance_id" string="R.Dist"/>
					<field name="right_near_id" string="R.Near"/>
					<field name="right_with_glasses_id" string="R.With Glasses"/>
					<field name="right_without_glasses_id" string="R.W/O Glasses"/>
					<field name="right_pin_id" string="R.PIN"/>
					<field name="right_iop_id" string="R.IOP"/>
				</tree>
			</field>
		</record>
		<record model="ir.ui.view" id="view_glass_prescription_line">
			<field name="name">glass_prescription_line</field>
			<field name="model">glass.prescription.line</field>
			<field name="type">form</field>
			<field name="arch" type="xml">
				<form string='glass prescription'>
					<sheet>
						<h2>Auto Reflectometer</h2>
						<h3 style="color:blue">Left Eye</h3>
						<group>
							<group>
								<field name="left_spherical_reflectometer"/>
								<field name="left_axis_reflectometer"/>
							</group>
							<group>
								<field name="left_cylindrical_reflectometer"/>
							</group>
						</group>
						<h3 style="color:blue">Right Eye</h3>
						<group>
							<group>
								<field name="right_spherical_reflectometer"/>
								<field name="right_axis_reflectometer"/>
							</group>
							<group>
								<field name="right_cylindrical_reflectometer"/>
							</group>
						</group>
						<h2>Glass Prescription</h2>
						<h3 style="color:blue">Left Eye</h3>
						<h4 style="color:#6666ff">Distance</h4>
						<group>
							<group>
								<field name="left_dist_spherical"/>
								<field name="left_dist_axis"/>
							</group>
							<group>
								<field name="left_dist_cylindrical"/>
							</group>
						</group>
						<h4 style="color:#6666ff">Near</h4>
						<group>
							<group>
								<field name="left_near_spherical"/>
								<field name="left_near_axis"/>
							</group>
							<group>
								<field name="left_near_cylindrical"/>
							</group>
						</group>
						<h4 style="color:#6666ff">Computer</h4>
						<group>
							<group>
								<field name="left_comp_spherical"/>
								<field name="left_comp_axis"/>
							</group>
							<group>
								<field name="left_comp_cylindrical"/>
							</group>
						</group>

						<h3 style="color:blue">Right Eye</h3>
						<h4 style="color:#6666ff">Distance</h4>
						<group>
							<group>
								<field name="right_dist_spherical"/>
								<field name="right_dist_axis"/>
							</group>
							<group>
								<field name="right_dist_cylindrical"/>
							</group>
						</group>
						<h4 style="color:#6666ff">Near</h4>
						<group>
							<group>
								<field name="right_near_spherical"/>
								<field name="right_near_axis"/>
							</group>
							<group>
								<field name="right_near_cylindrical"/>
							</group>
						</group>
						<h4 style="color:#6666ff">Computer</h4>
						<group>
							<group>
								<field name="right_comp_spherical"/>
								<field name="right_comp_axis"/>
							</group>
							<group>
								<field name="right_comp_cylindrical"/>
							</group>
						</group>
					</sheet>
				</form>
			</field>
		</record>

		<record model="ir.ui.view" id="glass_prescription_line_tree">
			<field name="name">glass_prescription_line</field>
			<field name="model">glass.prescription.line</field>
			<field name="type">tree</field>
			<field name="arch" type="xml">
				<tree>
					<field name="left_spherical_reflectometer" string="L.Spl RFl"></field>
					<field name="left_cylindrical_reflectometer" string="L.Cyl RFl"></field>
					<field name="left_axis_reflectometer" string="L.Axis RFl"></field>
					<field name="right_spherical_reflectometer" string="R.Spl Rfl"></field>
					<field name="right_cylindrical_reflectometer" string="R.Cyl RFl"></field>
					<field name="right_axis_reflectometer" string="R.Axis RFl"></field>
					
					
				</tree>
			</field>
		</record>
		<record model="ir.ui.view" id="view_distance">
			<field name="name">Distance Readings</field>
			<field name="model">distance</field>
			<field name="type">form</field>
			<field name="arch" type="xml">
				<form string='Distance Readings'>
					<sheet>
						<group>
							<group>
							<field name="name"/>
							</group>
							<group/>
						</group>
					</sheet>
				</form>
			</field>
		</record>
		<record model="ir.ui.view" id="view_near">
			<field name="name">Near Readings</field>
			<field name="model">near</field>
			<field name="type">form</field>
			<field name="arch" type="xml">
				<form string='Near Readings'>
					<sheet>
						<group>
							<group>
							<field name="name"/>
							</group>
							<group/>
						</group>
					</sheet>
				</form>
			</field>
		</record>
		<record model="ir.ui.view" id="view_with_glasses">
			<field name="name">With Glasses Readings</field>
			<field name="model">with.glasses</field>
			<field name="type">form</field>
			<field name="arch" type="xml">
				<form string='With Glasses Readings'>
					<sheet>
						<group>
							<group>
							<field name="name"/>
							</group>
							<group/>
						</group>
					</sheet>
				</form>
			</field>
		</record>
		<record model="ir.ui.view" id="view_without_glasses">
			<field name="name">Without Glasses Readings</field>
			<field name="model">without.glasses</field>
			<field name="type">form</field>
			<field name="arch" type="xml">
				<form string='Without Glasses Readings'>
					<sheet>
						<group>
							<group>
							<field name="name"/>
							</group>
							<group/>
						</group>
					</sheet>
				</form>
			</field>
		</record>
		<record model="ir.ui.view" id="view_pin">
			<field name="name">PIN</field>
			<field name="model">pin</field>
			<field name="type">form</field>
			<field name="arch" type="xml">
				<form string='PIN'>
					<sheet>
						<group>
							<group>
							<field name="name"/>
							</group>
							<group/>
						</group>
					</sheet>
				</form>
			</field>
		</record>
		<record model="ir.ui.view" id="view_iop">
			<field name="name">IOP</field>
			<field name="model">iop</field>
			<field name="type">form</field>
			<field name="arch" type="xml">
				<form string='IOP'>
					<sheet>
						<group>
							<group>
							<field name="name"/>
							</group>
							<group/>
						</group>
					</sheet>

				</form>
			</field>
		</record>
		<record model="ir.actions.act_window" id="distance_action">
			<field name="name">Distance</field>
			<field name="type">ir.actions.act_window</field>
			<field name="res_model">distance</field>
		</record>
		<record model="ir.actions.act_window" id="near_action">
			<field name="name">Near</field>
			<field name="type">ir.actions.act_window</field>
			<field name="res_model">near</field>
		</record>
		<record model="ir.actions.act_window" id="with_glasses_action">
			<field name="name">With Glasses</field>
			<field name="type">ir.actions.act_window</field>
			<field name="res_model">with.glasses</field>
		</record>
		<record model="ir.actions.act_window" id="without_glasses_action">
			<field name="name">Without Glasses</field>
			<field name="type">ir.actions.act_window</field>
			<field name="res_model">without.glasses</field>
		</record>
		<record model="ir.actions.act_window" id="pin_action">
			<field name="name">PIN</field>
			<field name="type">ir.actions.act_window</field>
			<field name="res_model">pin</field>
		</record>
		<record model="ir.actions.act_window" id="iop_action">
			<field name="name">IOP</field>
			<field name="type">ir.actions.act_window</field>
			<field name="res_model">iop</field>
		</record>
		<record model="ir.actions.act_window" id="assistance_doctor_action">
			<field name="name">IOP</field>
			<field name="type">ir.actions.act_window</field>
			<field name="res_model">iop</field>
		</record>

		<!-- <menuitem name="Assistance Doctor" id="assistance_doctor_menu" parent="medical_menu" sequence="2"/> -->
		
		




	</data>
</odoo>
