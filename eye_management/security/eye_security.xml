<?xml version="1.0" encoding="utf-8"?>
<odoo>
	<data>
		<record id="eye_type_category" model="ir.module.category">
			<field name="name">eye type access category</field>
		</record>

	    <record id="group_eye_mngt_user" model="res.groups">
	        <field name="name">Eye Management</field>
	    </record>

		<record id="group_super_admin" model="res.groups">
			<field name="name">Super Admin</field>
		</record>

	    <record id="group_eye_ecp" model="res.groups">
	        <field name="name">Eye Management ecp</field>
			<field name="category_id" ref="eye_type_category"/>
	    </record>

	    <record id="group_kepala_toko" model="res.groups">
	        <field name="name">Eye Management ecp Kepala Toko</field>
			<field name="category_id" ref="eye_type_category"/>
	    </record>

		<record id="group_admin" model="res.groups">
			<field name="name">Group Admin</field>
			<field name="category_id" ref="eye_type_category"/>
			<!-- <field name="implied_ids" eval="[(4, ref('group_eye_ecp'))]"/> -->
		</record>


		<record id="filter_app_secabang_ecp" model="ir.rule">
			<field name="name">App secabang ecp</field>
			<field name="model_id" ref="eye_management.model_medical_appointment"/>
			<field name="domain_force">[('company_id', '=', user.company_id.id),('is_deleted','!=',1)]</field>
			<!-- <field name="domain_force">[('is_deleted','!=',1)]</field> -->
			<!-- <field name="groups" eval="[Command.link(ref('eye_management.group_eye_ecp')),Command.link(ref('eye_management.group_kepala_toko'))]"/> -->
			<field name="groups" eval="[(4, ref('group_eye_ecp')), (4, ref('group_kepala_toko'))]"/>
		</record>

		<record id="filter_is_deleted" model="ir.rule">
			<field name="name">App non deleted</field>
			<field name="model_id" ref="eye_management.model_medical_appointment"/>
			<field name="domain_force">[('is_deleted','!=', 1)]</field>
			<field name="groups" eval="[(4, ref('group_admin'))]"/>
		</record>

		<record id="group_crm_agent" model="res.groups">
			<field name="name">crm agent</field>
			<field name="category_id" ref="eye_type_category"/>
			<field name="comment">ini grup untuk ces crs</field>
		</record>

	</data>
</odoo>