<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="satset_eye_type_category" model="ir.module.category">
            <field name="name">eye type access category satset</field>
        </record>

        <record id="group_satset_non" model="res.groups">
            <field name="name">non-user rme</field>
            <field name="category_id" ref="satset_eye_type_category"/>
        </record>

        <record id="group_satset_admin" model="res.groups">
            <field name="name">admin rme</field>
            <field name="category_id" ref="satset_eye_type_category"/>
        </record>

        <record id="group_satset_dokter" model="res.groups">
            <field name="name">dokter rme</field>
            <field name="category_id" ref="satset_eye_type_category"/>
            <!-- <field name="implied_ids" eval="[(4, ref('group_satset_admin'))]" /> -->
            <!-- <field name="implied_ids" eval="[(4, ref('group_satset_admin'))]"/> -->
        </record>

        <record id="akses_dokter_rme" model="ir.rule">
            <field name="name">hak akses dokter</field>
            <field name="model_id" ref="v_satset.model_satset_appointment"></field>
            <field name="domain_force">[('doctor_id.res_partner_physician_id', '=', user.partner_id.id)]</field>
            <field name="groups" eval="[(4, ref('group_satset_dokter'))]"></field>
        </record>

    </data>
</odoo>
