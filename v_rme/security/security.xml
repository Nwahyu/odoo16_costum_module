<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="rme_groups" model="ir.module.category">
        <field name="name">rme type</field>
    </record>

    <record id="rme_dokter" model="res.groups">
        <field name="name">rme dokter</field>
        <field name="category_id" ref="rme_category" />
    </record>






    <record id="filter_rme_dokter" model="ir.rule">
        <field name="name">rme dokter</field>
        <field name="model_id" ref="v_rme.model_vio_rme"/>
        <field name="domain_force">[('doctor_id', '=', user.physician_id.id)]</field>
        <field name="groups" eval="[(4, ref('rme_dokter'))]"/>
    </record>

</odoo>
