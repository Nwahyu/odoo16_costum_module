<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record model="ir.ui.view" id="medical_patient_view_city">
            <field name="name">medical.patient.view.city</field>
            <field name="model">medical.patient</field>
            <field name="inherit_id" ref="eye_management.medical_patient_view"/>
            <field name="arch" type="xml">
                <xpath expr="//field[@name='city']" position="replace">
                    <field name="district_id" placeholder="district" options="{'no_create':True, 'no_create_edit':True}"/>
                    <field name="city_id" placeholder="City" required="1" options="{'no_create':True, 'no_create_edit':True}"/>
                </xpath>
            </field>
        </record>
    </data>
</odoo>