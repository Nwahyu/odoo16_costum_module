<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!-- State -->
        <record id="view_state_district_tree" model="ir.ui.view">
            <field name="name">state.district.tree</field>
            <field name="model">state.district</field>
            <field name="arch" type="xml">
                <tree string="State" editable="bottom">
                    <field name="name"/>
                    <field name="code"/>
                    <field name="city_id" options="{'no_create': True, 'no_open': True}"/>
                </tree>
            </field>
        </record>

        <record id="view_state_district_form" model="ir.ui.view">
            <field name="name">state.district.form</field>
            <field name="model">state.district</field>
            <field name="arch" type="xml">
                <form string="State">
                    <sheet>
                        <group>
                            <field name="name"/>
                            <field name="code"/>
                            <field name="city_id" options='{"no_open": True, "no_create": True}'/>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

        <record id="view_state_district_search" model="ir.ui.view">
            <field name="name">state.district.search</field>
            <field name="model">state.district</field>
            <field name="arch" type="xml">
                <search string="">
                    <field name="name"/>
                    <field name="city_id"/>
                    <group string="Group By">
                        <filter name="groupby_state" string="city" context="{'group_by': 'city_id'}"/>
                    </group>
                </search>
            </field>
        </record>

