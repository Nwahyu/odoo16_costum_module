                    Create a City
                </p><p>
                    City belong to state and are part of your contacts' addresses.
                </p>
            </field>
        </record> -->
        

        <record id="state_district_action" model="ir.actions.act_window">
            <field name="name">District</field>
            <field name="res_model">state.district</field>
            <field name="view_mode">tree,form</field>
            <!-- <field name="domain">[]</field>
            <field name="context">{}</field> -->
            <field name="help" type="html">
                <p>create youtr first district</p>
            </field>
        </record>

        <!-- action="mel_state_city.action_state_district" -->
        <menuitem id="menu_state_district"
        action="state_district_action"
        parent="contacts.menu_localisation"
        sequence="5"/>

    </data>
</odoo>
